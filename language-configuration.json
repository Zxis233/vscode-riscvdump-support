{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    [
      "<",
      ">"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "<",
      "close": ">",
      "notIn": [
        "comment",
        "string"
      ]
    },
    {
      "open": "(",
      "close": ")",
      "notIn": [
        "comment",
        "string"
      ]
    },
    {
      "open": "[",
      "close": "]",
      "notIn": [
        "comment",
        "string"
      ]
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "comment",
        "string"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "comment",
        "string"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "<",
      ">"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@%^&*()=+[\\]{}\\\\|;:'\",.<>/?\\s]+)"
}
